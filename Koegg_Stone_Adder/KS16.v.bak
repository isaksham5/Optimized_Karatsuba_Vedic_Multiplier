module KS16 (
    input  [15:0] x, y,
    input cin,
    output [15:0] sum,
    output cout
);

// Step 1: Generate & Propagate
wire [15:0] G, P;

genvar i;

generate
for(i=0; i<16; i=i+1) begin : and_xor
initialize ini(x[i],y[i],G[i],P[i]);
end
endgenerate

// Step 2: Stage 1 (distance = 1)
wire [15:0] G1, P1;


grey_cell b1(G[0],P[0],cin,G1[0]);
black_cell b2(G[1],P[1],G[0],P[0],G1[1],P1[1]);
black_cell b3(G[2],P[2],G[1],P[1],G1[2],P1[2]);
black_cell b4(G[3],P[3],G[2],P[2],G1[3],P1[3]);
black_cell b5(G[4],P[4],G[3],P[3],G1[4],P1[4]);
black_cell b6(G[5],P[5],G[4],P[4],G1[5],P1[5]);
black_cell b7(G[6],P[6],G[5],P[5],G1[6],P1[6]);
black_cell b8(G[7],P[7],G[6],P[6],G1[7],P1[7]);
black_cell b9(G[8],P[8],G[7],P[7],G1[8],P1[8]);
black_cell b10(G[9],P[9],G[8],P[8],G1[9],P1[9]);
black_cell b11(G[10],P[10],G[9],P[9],G1[10],P1[10]);
black_cell b12(G[11],P[11],G[10],P[10],G1[11],P1[11]);
black_cell b13(G[12],P[12],G[11],P[11],G1[12],P1[12]);
black_cell b14(G[13],P[13],G[12],P[12],G1[13],P1[13]);
black_cell b15(G[14],P[14],G[13],P[13],G1[14],P1[14]);
black_cell b16(G[15],P[15],G[14],P[14],G1[15],P1[15]);

// Step 3: Stage 2 (distance = 2)
wire [14:0] G2, P2;

grey_cell b17(G1[1],P1[1],cin,G2[0]);
grey_cell b18(G1[2],P1[2],G1[0],G2[1]);
black_cell b19(G1[3],P1[3],G1[1],P1[1],G2[2],P2[2]);
black_cell b20(G1[4],P1[4],G1[2],P1[2],G2[3],P2[3]);
black_cell b21(G1[5],P1[5],G1[3],P1[3],G2[4],P2[4]);
black_cell b22(G1[6],P1[6],G1[4],P1[4],G2[5],P2[5]);
black_cell b23(G1[7],P1[7],G1[5],P1[5],G2[6],P2[6]);
black_cell b24(G1[8],P1[8],G1[6],P1[6],G2[7],P2[7]);
black_cell b25(G1[9],P1[9],G1[7],P1[7],G2[8],P2[8]);
black_cell b26(G1[10],P1[10],G1[8],P1[8],G2[9],P2[9]);
black_cell b27(G1[11],P1[11],G1[9],P1[9],G2[10],P2[10]);
black_cell b28(G1[12],P1[12],G1[10],P1[10],G2[11],P2[11]);
black_cell b29(G1[13],P1[13],G1[11],P1[11],G2[12],P2[12]);
black_cell b30(G1[14],P1[14],G1[12],P1[12],G2[13],P2[13]);
black_cell b31(G1[15],P1[15],G1[13],P1[13],G2[14],P2[14]);  

// Step 4: Stage 3 (distance = 4)

wire [12:0] G3, P3;

grey_cell b32(G2[2],P2[2],cin,G3[0]);
grey_cell b33(G2[3],P2[3],G1[0],G3[1]);
grey_cell b34(G2[4],P2[4],G2[0],G3[2]);
grey_cell b35(G2[5],P2[5],G2[1],G3[3]);
black_cell b36(G2[6],P2[6],G2[2],G3[4]);
black_cell b37(G2[7],P2[7],G2[3],P2[3],G3[5]);
black_cell b38(G2[8],P2[8],G2[4],P2[4],G3[6]);
black_cell b39(G2[9],P2[9],G2[5],P2[5],G3[7]);
black_cell b40(G2[10],P2[10],G2[6],P2[6],G3[8]);
black_cell b41(G2[11],P2[11],G2[7],P2[7],G3[9]);
black_cell b42(G2[12],P2[12],G2[8],P2[8],G3[10]);
black_cell b43(G2[13],P2[13],G2[9],P2[9],G3[11]);
black_cell b44(G2[14],P2[14],G2[10],P2[10],G3[12]);

//Step 5: Stage 4 (distance = 8)
wire [7:0] G4, P4;

grey_cell b45(G3[4],P3[4],cin,G4[0]);
grey_cell b46(G3[5],P3[5],G1[0],G4[1]);
grey_cell b47(G3[6],P3[6],G2[0],G4[2]);
grey_cell b48(G3[7],P3[7],G2[1],G4[3]);
grey_cell b49(G3[8],P3[8],G3[0],G4[4]);
grey_cell b50(G3[9],P3[9],G3[1],G4[5]);
grey_cell b51(G3[10],P3[10],G3[2],G4[6]);
grey_cell b52(G3[11],P3[11],G3[3],G4[7]);
grey_cell b53(G3[12],P3[12],G3[4],cout);


// Step 6: Sum
xor(sum[0], P[0], cin);
xor(sum[1], P[1], G1[0]);   
xor(sum[2], P[2], G2[0]);
xor(sum[3], P[3], G2[1]);
xor(sum[4], P[4], G3[0]);
xor(sum[5], P[5], G3[1]);
xor(sum[6], P[6], G3[2]);
xor(sum[7], P[7], G3[3]);
xor(sum[8], P[8], G4[0]);
xor(sum[9], P[9], G4[1]);
xor(sum[10], P[10], G4[2]);
xor(sum[12], P[12], G4[3]);
xor(sum[11], P[11], G4[4]);
xor(sum[13], P[13], G4[5]);
xor(sum[14], P[14], G4[6]);
xor(sum[15], P[15], G4[7]);

endmodule